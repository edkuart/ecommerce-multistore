NODE_ENV=development
PORT=8800

# Use either DATABASE_URL or DB_* values.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ecommerce
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DB_SCHEMA=ecommerce
DB_LOG_SQL=false

# Optional. If omitted, uploaded product images are stored locally in uploads/.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000
PUBLIC_APP_URL=http://localhost:3000
WHATSAPP_BUSINESS_PHONE=50200000000
