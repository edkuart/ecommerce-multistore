# ── Backend API ──────────────────────────────────────────────────────────────
# URL del backend Express. En producción reemplazar con dominio real.
NEXT_PUBLIC_API_URL=http://localhost:8800

# URL pública del frontend. Se usa para construir links en mensajes de WhatsApp.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── WhatsApp ──────────────────────────────────────────────────────────────────
# Número general de fallback en formato internacional sin + ni espacios.
# Ejemplo Guatemala: 50212345678
NEXT_PUBLIC_WA_PHONE=50200000000

# ── Moneda ────────────────────────────────────────────────────────────────────
# Código ISO 4217. Se usa en Intl.NumberFormat para formatear precios.
NEXT_PUBLIC_CURRENCY=GTQ

# ── Auth (solo servidor) ─────────────────────────────────────────────────────
# Token de API para autenticación server-side en proxies del dashboard.
# En uso normal queda vacío — la sesión se maneja con la cookie seller_token
# que se establece al hacer login en /dashboard/login.
# Solo se usa como fallback en entornos CI/CD o scripts automatizados.
SELLER_API_TOKEN=
